RoonVis/build/
RoonVis/Debug-*/
RoonVis/Release-*/
.derived-data/
RoonVis/.DerivedData/
xcuserdata/
*.xcuserdatad/

# macOS Finder metadata
.DS_Store

# CMake project-generator cache/output. RoonVis.xcodeproj is the checked-in
# artifact that matters; re-running the generator repopulates CMakeFiles/
# with regenerable cache state. Two compatibility Info.plists the checked-in
# project references are kept.
RoonVis/CMakeCache.txt
RoonVis/CMakeScripts/
RoonVis/Makefile
RoonVis/cmake_install.cmake
# Generated ANGLE source list (regenerated from vendor/angle .gni files each run)
RoonVis/angle_sources.cmake
# projectM sub-build tree (generated by add_subdirectory of vendor/projectm)
RoonVis/projectm-build/
# CPack config emitted by the projectM subproject; unused here
RoonVis/CPackConfig.cmake
RoonVis/CPackSourceConfig.cmake
RoonVis/CMakeFiles/*
!RoonVis/CMakeFiles/ANGLE.dir/
!RoonVis/CMakeFiles/ANGLE.dir/Info.plist
!RoonVis/CMakeFiles/RoonVis.dir/
!RoonVis/CMakeFiles/RoonVis.dir/Info.plist
build-host-tests/

# Local documentation clone for projectM reference.
projectm.wiki/

# Local test audio (provided for burn-in; not part of the repo)
slip.wav

# Local PR drafts (not committed)
docs/pr/

# Local reference clones (Apple sample + projectM docs/wiki; not part of the repo)
docs/MigratingOpenGLCodeToMetal/
docs/projectm/

# Instruments traces + scratch AI-session logs (local profiling artifacts, large)
*.trace/
tmp/

# Xcode shared scheme is hand-managed for profiling and clobbered by cmake -G Xcode
RoonVis/RoonVis.xcodeproj/xcshareddata/

# Auto-generated Xcode workspace shell for the hand-authored UITests project
# (its project.pbxproj + shared scheme are tracked; Xcode regenerates this dir).
RoonVis/UITests/RoonVisUITests.xcodeproj/project.xcworkspace/

# CodeGraph indexing opt-in (does not affect git — vendor/ holds only submodules,
# already tracked as gitlinks). CodeGraph ignores any dir named `vendor/` by
# default, which hid the vendored projectM tree (the preset transpiler lives in
# vendor/projectm/vendor/projectm-eval, plus hlslparser). The only supported
# override is a .gitignore negation, but you can't re-include under a fully
# excluded dir — so re-include vendor/, exclude its contents (keeps the large
# vendor/angle checkout out of the index), then re-include only projectM. Its
# third-party sub-deps (glm, glad, stb_image) and preset/test data are trimmed
# via codegraph.json `exclude`.
!vendor/
vendor/*
!vendor/projectm/
!vendor/projectm/**
Isosceles_CreamOfTheCrop_MilkdropPresetsPack.zip
docs/cotc-compat/*.tsv

# UI mockup reference images (not shipped; referenced from Theme.swift comment)
updatedui/
